function [x_m, f_m] = GoldenSection(a, b, k, E, f)
tic;
delta = E*k;
c = b - ((sqrt(5)-1)/2)*(b-a);
d = a + ((sqrt(5)-1)/2)*(b-a);
while abs(b-a)>E
    if (f(c)<=f(d))
        b=d;
        d=c;
        c=a+b-d;
    else
        a=c;
        c=d;
        d=a+b-c;
    end
x_m=(b+a)/2;
f_m=f(x_m);
end
end